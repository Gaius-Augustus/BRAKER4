# Test data files too large for git (downloaded on demand)
test_data/RNAseq.bam
test_data/reads_R1.fastq*
test_data/reads_R2.fastq*
test_data/Arabidopsis_thaliana.fa
test_data/Ostreococcus_tauri.fa
test_data/Viridiplantae.fa
test_data/isoseq_lib2.bam
test_data/LUCA.h5

# BAM index files (generated by pipeline)
*.bam.bai

# Snakemake working files
.snakemake/
output/

# Singularity containers
*.sif
.singularity_cache/

# AUGUSTUS config copies
augustus_config/

# Logs and benchmarks
logs/
benchmarks/

# Shared data (downloaded BUSCO databases etc.)
shared_data/

# Downloaded genomes in scenario dirs (too large for git)
test_scenarios/*/genome.fa
test_scenarios/*/genome.fna.gz

# NCBI config (created by SRA tools)
.ncbi/
*/.ncbi/

# AGAT runtime logs
braker.agat.log
**/braker.agat.log

# wget artifacts
.wget-hsts
*/.wget-hsts

# Python cache
__pycache__/
**/__pycache__/
*.pyc

# Fontconfig/matplotlib cache (created by containers)
**/.cache/

# BUSCO stray logs
**/busco_*.log

# Test results (generated by run_all_tests.sh)
test_scenarios/test_results_*/
test_scenarios_local/test_results_*/

graphify-out/*
!graphify-out/graph.json
!graphify-out/GRAPH_REPORT.md
!graphify-out/manifest.json
